  <diagram id="KnKWQzYQIOJu8tZZ2141" name="Views">
    <mxGraphModel grid="0" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="Yt1bRhX8YDctOHEmnDc4-1" parent="1" style="text;whiteSpace=wrap;fontSize=22;" value="CREATE VIEW UserPermissionDetail AS&#xa;SELECT &#xa;    u.UserName,&#xa;    p.Name AS PermissionName,&#xa;    r.Name AS RoleName,&#xa;    ps.Name AS PermSetName,&#xa;    r.ADGroup AS AssociatedADGroup,&#xa;    u.UserId,&#xa;    p.PermissionId&#xa;FROM User u&#xa;JOIN UserRole ur ON u.UserId = ur.UserId&#xa;JOIN Role r ON ur.RoleId = r.RoleId&#xa;JOIN RolePermSet rps ON r.RoleId = rps.RoleId&#xa;JOIN PermSet ps ON rps.PermSetId = ps.PermSetId&#xa;JOIN PermSetPermission psp ON ps.PermSetId = psp.PermSetId&#xa;JOIN Permission p ON psp.PermissionId = p.PermissionId;" vertex="1">
          <mxGeometry height="562" width="534" x="-692" y="-1045" as="geometry" />
        </mxCell>
        <mxCell id="Yt1bRhX8YDctOHEmnDc4-2" parent="1" style="text;whiteSpace=wrap;fontSize=22;" value="CREATE VIEW UserUniqueCapabilities AS&#xa;SELECT DISTINCT&#xa;    UserName,&#xa;    PermissionName&#xa;FROM UserPermissionDetail;" vertex="1">
          <mxGeometry height="194.45" width="490.58" x="-720" y="-479" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
